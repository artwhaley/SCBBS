  <Target Name="FixInfDriverVerFormat" AfterTargets="DriverPackageTarget" BeforeTargets="Inf2Cat" Condition="'$(EnableInf2cat)' == 'true'">
    <!-- StampInf writes "DriverVer = ..." (spaces). Inf2cat signability rejects that and reports "No installation INF". -->
    <!-- Use WorkingDirectory=$(OutDir) so the script needs no path argument. Combine script path so the quoted -File path does not end with \ (cmd \" bug). -->
    <PropertyGroup>
      <_FixInfDriverVerScript>$([System.IO.Path]::Combine('$(ProjectDir)', 'fix_Inf_DriverVer.ps1'))</_FixInfDriverVerScript>
    </PropertyGroup>
    <Exec WorkingDirectory="$(OutDir)" Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(_FixInfDriverVerScript)&quot; -OutDir &quot;$([System.String]::Copy('$(OutDir)').TrimEnd('\'))&quot; -ProjectDir &quot;$([System.String]::Copy('$(MSBuildProjectDirectory)').TrimEnd('\'))&quot; -Configuration &quot;$(Configuration)&quot;" />
  </Target>
