    <Platform Condition="'$(Platform)' == ''">x64</Platform>
    <RootNamespace>SCMFD_Joystick_B_Root</RootNamespace>
    <!-- Do NOT set WindowsTargetPlatformVersion to "10.0" alone: Microsoft.Cpp.WDK.props sets
         WDKBuildFolder from it, and build\10.0\WindowsDriver.Default.props does not exist — WDK
         imports are skipped, DDK_INC_PATH stays empty, and wdf.h is not found. Leave unset here
         so WDK + VS pick a real kit (e.g. 10.0.26100.0), or pin an installed full version. -->
    <!-- MSBuild InfVerif task can fail to load x86 InfVerif.dll from some hosts; run infverif.exe manually before install. -->
    <SkipPackageVerification>true</SkipPackageVerification>
    <!-- Produce SCMFD_Joystick_B_Root.cat so pnputil accepts the package (CatalogFile= in INF). Test-sign runs after Inf2Cat. -->
    <EnableInf2cat>true</EnableInf2cat>
