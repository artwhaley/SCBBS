<ui:FluentWindow x:Class="StarCitizenButtonBoxServer.BindingsEditorWindow"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:vm="clr-namespace:StarCitizenButtonBoxServer"
                  xmlns:bind="clr-namespace:StarCitizenButtonBoxServer"
                  xmlns:conv="clr-namespace:StarCitizenButtonBoxServer"
                  Title="Bindings Editor"
                  Icon="Star Citizen BBS.ico"
                  Width="960" Height="580"
                  MinWidth="920" MinHeight="560"
                  ExtendsContentIntoTitleBar="True"
                  WindowBackdropType="Mica"
                  WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:IntStringConverter x:Key="IntString"/>
            <HierarchicalDataTemplate DataType="{x:Type vm:CategoryNode}" ItemsSource="{Binding Commands}">
                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="11"/>
            </HierarchicalDataTemplate>
            <DataTemplate DataType="{x:Type bind:CommandItem}">
                <TextBlock Text="{Binding Label}" Padding="4,3"/>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Bindings Editor" Grid.Row="0" />

        <Grid Grid.Row="1" Margin="18,0,18,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="8" Padding="18,10" Margin="0,0,0,10"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <ui:TextBlock Text="Bindings Editor" FontTypography="Title" VerticalAlignment="Center"/>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,6">
                        <StackPanel>
                            <TextBlock Text="BINDING TARGET" FontWeight="SemiBold" FontSize="10"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,2"/>
                            <ui:TextBlock Text="{Binding SelectedCommandLabel}"
                                          FontTypography="BodyStrong"
                                          Foreground="{DynamicResource SystemAccentColorBrush}"
                                          TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" MinHeight="280">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="9*" MinWidth="180"/>
                    <ColumnDefinition Width="17*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,14,0" CornerRadius="8"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1" Padding="6,8">
                    <TreeView x:Name="CommandTree" Background="Transparent" BorderThickness="0"
                              ItemsSource="{Binding Categories}"
                              SelectedItemChanged="CommandTree_OnSelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="2,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Border>

                <Border Grid.Column="1" CornerRadius="8"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1" Padding="16,14">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <StackPanel>
                                <TextBlock Text="MODIFIERS" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,8"/>
                                <UniformGrid Columns="3" Margin="0,0,0,14">
                                    <CheckBox Content="Left Ctrl" IsChecked="{Binding LeftCtrl, Mode=TwoWay}" Margin="0,5"/>
                                    <CheckBox Content="Left Shift" IsChecked="{Binding LeftShift, Mode=TwoWay}" Margin="0,5"/>
                                    <CheckBox Content="Left Alt" IsChecked="{Binding LeftAlt, Mode=TwoWay}" Margin="0,5"/>
                                    <CheckBox Content="Right Ctrl" IsChecked="{Binding RightCtrl, Mode=TwoWay}" Margin="0,5"/>
                                    <CheckBox Content="Right Shift" IsChecked="{Binding RightShift, Mode=TwoWay}" Margin="0,5"/>
                                    <CheckBox Content="Right Alt" IsChecked="{Binding RightAlt, Mode=TwoWay}" Margin="0,5"/>
                                </UniformGrid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Key" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" x:Name="KeyInput"
                                             PreviewKeyDown="KeyInput_OnPreviewKeyDown"
                                             Text="{Binding KeyFieldDisplayText, Mode=OneWay}"
                                             Margin="0,0,10,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseInputActionSet}" Value="True">
                                                        <Setter Property="FontStyle" Value="Italic"/>
                                                        <Setter Property="TextAlignment" Value="Center"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock Grid.Column="2" Text="Hold (ms)" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="3" 
                                             Text="{Binding HoldTimeMs, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource IntString}}"/>
                                </Grid>
                                <TextBlock Text="Focus the key field and press a key to capture."
                                           FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,10"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="MOUSE BUTTON" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                <UniformGrid Columns="5" Margin="0,0,0,12">
                                    <Button Content="Left" Tag="LeftClick" Click="MouseInputActionButton_Click" Padding="6,8" Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseLeft}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Middle" Tag="MiddleClick" Click="MouseInputActionButton_Click" Padding="6,8" Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseMiddle}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Right" Tag="RightClick" Click="MouseInputActionButton_Click" Padding="6,8" Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseRight}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Scroll Up" Tag="ScrollUp" Click="MouseInputActionButton_Click" Padding="6,8" Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseScrollUp}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Scroll Down" Tag="ScrollDown" Click="MouseInputActionButton_Click" Padding="6,8">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseScrollDown}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SystemAccentColorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,0,0,14"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:Button Content="Clear Binding" Padding="18,10" Click="Clear_Click" Appearance="Secondary"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</ui:FluentWindow>
