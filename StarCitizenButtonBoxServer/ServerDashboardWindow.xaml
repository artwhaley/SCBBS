<ui:FluentWindow x:Class="StarCitizenButtonBoxServer.ServerDashboardWindow"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  Title="Star Citizen Button Box Server"
                  Icon="Star Citizen BBS.ico"
                  Width="640" Height="530"
                  MinWidth="640" MinHeight="530"
                  ExtendsContentIntoTitleBar="True"
                  WindowBackdropType="Mica"
                  WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Star Citizen Button Box Server" Grid.Row="0" />

        <Grid Grid.Row="1" Margin="18,0,18,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="300"/>
                <RowDefinition x:Name="LogRowDefinition" Height="0"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="8" Padding="24,18" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <StackPanel HorizontalAlignment="Center">
                    <Border Background="White" CornerRadius="6" Padding="24,10" Margin="0,0,0,10" 
                            HorizontalAlignment="Center" BorderBrush="#888" BorderThickness="1">
                        <ui:TextBlock x:Name="TxtEndpoint" Text="127.0.0.1:8795"
                                      FontSize="32" FontWeight="Bold" Foreground="Black" />
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                    <ui:TextBlock Text="PANELS" FontTypography="BodyStrong" Margin="6,0,0,10"/>
                    <ui:Button x:Name="BtnBindings" Content="Bindings Editor"
                               Appearance="Secondary" HorizontalAlignment="Stretch"
                               Padding="12,14" Margin="0,0,0,8" Click="Bindings_Click"/>
                    <ui:Button x:Name="BtnLog" Content="Show Log"
                               Appearance="Secondary" HorizontalAlignment="Stretch"
                               Padding="12,14" Click="ToggleLog_Click"/>
                </StackPanel>

                <Border x:Name="ClientsPanel" Grid.Column="1" CornerRadius="8" Padding="16,14"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <ui:TextBlock Text="Connected Clients" FontTypography="Subtitle"/>
                            <ui:TextBlock x:Name="TxtClientCount" Text="0 connected client(s)"
                                          Foreground="{DynamicResource SystemAccentColorBrush}"
                                          FontSize="12" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}" MinHeight="220">
                            <ListBox x:Name="ClientsList" Background="Transparent" BorderThickness="0"
                                     Margin="8,0,8,0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>

            <Border x:Name="LogAreaBorder" Grid.Row="2" Visibility="Collapsed" Margin="0,12,0,0"
                    CornerRadius="8" Padding="14,12"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1">
                <DockPanel>
                    <ui:TextBlock DockPanel.Dock="Top" Text="Server Log"
                                  FontTypography="Subtitle" Margin="0,0,0,10"/>
                    <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" MinHeight="200"
                             FontFamily="Cascadia Code, Consolas" FontSize="12"
                             Background="Transparent" BorderThickness="0"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
